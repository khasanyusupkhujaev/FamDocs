TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Mini App: public HTTPS URL (must match what you set in BotFather / menu button).
# Dev with ngrok: run `ngrok http 8080` and paste the https URL (e.g. *.ngrok-free.dev).
#
# Ngrok free “You are about to visit…” page: ngrok injects that at their edge *before* your
# server runs. The Mini App’s first full-page load is a normal browser navigation and cannot
# send custom headers, so this project cannot remove that screen on free ngrok from code alone.
# To avoid it completely: use a paid ngrok plan, host on a real domain, or use Cloudflare Tunnel
# (cloudflared) / another tunnel without that interstitial.
# API/fetch calls from the app already send ngrok-skip-browser-warning where possible.
WEBAPP_PUBLIC_URL=https://your-tunnel-or-domain.example.com

WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
WEBAPP_MENU_BUTTON_TEXT=FamDocs

# Max documents per vault on the free tier (web + Telegram). Set to 0 for no limit (e.g. self-host).
# FAMDOC_FREE_DOCUMENT_LIMIT=10

# --- Paid extra slots (Telegram Payments) ---
# Empty FAMDOC_PAYMENT_PROVIDER_TOKEN = pay with Telegram Stars (XTR). Otherwise paste provider token from @BotFather.
# FAMDOC_PAYMENT_PROVIDER_TOKEN=
# FAMDOC_UPGRADE_STARS=150
# FAMDOC_UPGRADE_EXTRA_SLOTS=50
# Fiat (when using a card provider): FAMDOC_UPGRADE_CURRENCY=USD and FAMDOC_UPGRADE_AMOUNT_MINOR=299  ($2.99)

# --- PayTech.uz (Payme / Click) — set FAMDOC_BILLING_MODE=payme or click ---
# License: https://pay-tech.uz/console
# Webhooks (HTTPS, same host as WEBAPP_PUBLIC_URL):
#   POST .../payments/payme/webhook
#   POST .../payments/click/webhook
# PAYTECH_LICENSE_API_KEY=your_paytech_license_api_key
# FAMDOC_BILLING_MODE=telegram
# FAMDOC_PAYTECH_PRICE_UZS=49990
# FAMDOC_PAYME_MERCHANT_ID=
# FAMDOC_PAYME_KEY=
# FAMDOC_PAYME_TEST=1
# FAMDOC_CLICK_SERVICE_ID=
# FAMDOC_CLICK_MERCHANT_ID=
# FAMDOC_CLICK_MERCHANT_USER_ID=
# FAMDOC_CLICK_SECRET_KEY=
# FAMDOC_CLICK_TEST=1

# --- Storage ---
# Blobs: local folder vs S3/R2. If you set bucket + access keys below, storage defaults
# to s3 even when FAMDOC_STORAGE is unset — so uploads do not silently stay on disk.
# Use FAMDOC_STORAGE=local for simple local development.
FAMDOC_STORAGE=local

# S3-compatible (required when FAMDOC_STORAGE=s3). Endpoint = account API URL only — no bucket path.
# Example R2: https://<account_id>.r2.cloudflarestorage.com
# FAMDOC_S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# FAMDOC_S3_BUCKET=your-bucket
# FAMDOC_S3_ACCESS_KEY_ID=your_access_key_id
# FAMDOC_S3_SECRET_ACCESS_KEY=your_secret_access_key
# FAMDOC_S3_REGION=auto
# FAMDOC_S3_PREFIX=famdoc

# Logos in the same R2/S3 bucket (Telegram /start photo, Mini App, /brand/*). Plain PNGs, not
# app-encrypted document blobs. If unset, the app tries {FAMDOC_S3_PREFIX}/brand/Logo_*.png first,
# then common paths without prefix: brand/logo-transparent.png, brand/logo.png.
# Override with the exact object key, e.g. FAMDOC_LOGO_TRANSPARENT_KEY=brand/logo-transparent.png
# FAMDOC_LOGO_TRANSPARENT_KEY=
# FAMDOC_LOGO_SOLID_KEY=

# R2/S3: the API token or IAM user must allow Object Read & Write (and List) on this bucket.
# Read-only credentials cause AccessDenied on upload and missing previews.

# AES-256-GCM encryption for blobs at rest (recommended in production).
# Generate: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# FAMDOC_FILE_MASTER_KEY=

# --- Manual bank transfer (no Stars / PayTech invoice) ---
# Set FAMDOC_BILLING_MODE=manual. User picks a tier, gets QR + FAMDOC-<telegram_user_id>.
# After you verify payment: /grant <telegram_user_id> <slots> in Telegram.
# FAMDOC_BILLING_MODE=manual
# FAMDOC_TRANSFER_CARD=5614 6887 0641 4637
# Optional second line (recipient name, bank):
# FAMDOC_TRANSFER_INSTRUCTIONS=
# Tier prices (UZS per month) and extra document slots (defaults: 10k→10, 25k→20, 50k→40):
# FAMDOC_TIER1_UZS=10000
# FAMDOC_TIER1_SLOTS=10
# FAMDOC_TIER2_UZS=25000
# FAMDOC_TIER2_SLOTS=20
# FAMDOC_TIER3_UZS=50000
# FAMDOC_TIER3_SLOTS=40
# Admin by @username (resolved at startup) and/or numeric ids:
# FAMDOC_ADMIN_USERNAMES=khacankhon
# FAMDOC_ADMIN_TELEGRAM_IDS=
# Web admin: https://<your-host>/admin
# — Telegram button: same ID/username as above; @BotFather /setdomain = WEBAPP_PUBLIC_URL host.
# — Or ID + secret: set a long random string, then sign in at /admin with your Telegram ID + this secret.
# FAMDOC_ADMIN_PANEL_SECRET=
# JSON stats (browser session after login): GET https://<your-host>/admin/stats

# For invite links: t.me/<username>?start=join_...
# TELEGRAM_BOT_USERNAME=YourBotName
